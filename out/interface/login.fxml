<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="563.0" prefWidth="857.0" style="-fx-background-color: #E1FFFF;"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx"
            fx:controller="controllers.LoginController">

   <Pane layoutX="309.0" layoutY="250.0" prefHeight="236.0" prefWidth="254.0"
         style="-fx-background-color: #FFFFFF;">
      <children>
         <TextField fx:id="txtUsuario" layoutX="21.0" layoutY="47.0" prefWidth="200" />
         <TextField fx:id="txtPassword" layoutX="21.0" layoutY="118.0" prefWidth="200" />
         <Label layoutX="21.0" layoutY="24.0" text="Usuario:" />
         <Label layoutX="21.0" layoutY="90.0" text="Contraseña:" />
         <Button fx:id="btnIngresar" onAction="#loginAction"
                  prefHeight="26.0" prefWidth="200.0"
                  style="-fx-background-color: #FF0303;" text="Ingresar">
            <font>
               <Font size="17.0" />
            </font>
         </Button>
      </children>
   </Pane>

   <ImageView fitHeight="172.0" fitWidth="189.0" layoutX="345.0" layoutY="66.0" pickOnBounds="true" preserveRatio="true">
      <image>
         <Image url="@747e63d5-c24e-4b1e-8622-61cde71cd610.png" />
      </image>
   </ImageView>
</AnchorPane>
