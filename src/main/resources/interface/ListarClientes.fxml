<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?> <BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
                                        fx:controller="controllers.ListarClientesController"
                                        prefHeight="500.0" prefWidth="500.0">

    <top>
        <VBox alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <Label text="Listado Completo de Clientes">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" top="20.0"/>
                    </VBox.margin>
                </Label>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="10.0" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <ComboBox fx:id="cmbFiltroEstado" prefWidth="150" />

                <TableView fx:id="tblClientes" prefHeight="400.0" prefWidth="480.0">
                    <columns>
                        <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre"/>
                        <TableColumn fx:id="colApellido" prefWidth="120.0" text="Apellido"/>
                        <TableColumn fx:id="colDocumento" prefWidth="120.0" text="Documento"/>
                        <TableColumn fx:id="colFechaAlta" prefWidth="100.0" text="Fecha Alta"/>
                        <TableColumn fx:id="colNumeroVisitas" prefWidth="80.0" text="Nº Visitas"/>
                        <TableColumn fx:id="colEstado" prefWidth="80.0" text="Estado"/>
                        <TableColumn fx:id="colAccion" prefWidth="120.0" text="Acceder al Historial"/>
                    </columns>
                    <VBox.margin>
                        <Insets left="20.0" right="20.0"/>
                    </VBox.margin>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#handleCerrar" text="Cerrar"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>