<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Separator?>

<AnchorPane fx:controller="controllers.ModuloClienteController" prefHeight="750.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@/resource/styles.css">
    <children>
        <!-- Encabezado -->
        <AnchorPane prefHeight="100.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="100.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                    <children>
                        <ImageView fitHeight="86.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@747e63d5-c24e-4b1e-8622-61cde71cd610.png" />
                            </image>
                        </ImageView>
                        <VBox prefHeight="94.0" prefWidth="434.0">
                            <children>
                                <Label text="PeluqPro" styleClass="label-header">
                                    <font>
                                        <Font name="Candara" size="41.0" />
                                    </font>
                                </Label>
                                <Label text="MODULO CLIENTES" />
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                    </padding>
                </HBox>
            </children>
        </AnchorPane prefHeight="100.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- Menú lateral -->
        <VBox layoutY="95.0" prefWidth="200.0" spacing="10.0" AnchorPane.topAnchor="100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
            <children>
                <Label text="Seleccione una opción." prefWidth="206.0" prefHeight="18.0" />

                <Button fx:id="btnAltaCliente" text="ALTA" prefWidth="170.0" prefHeight="45.0" styleClass="menu-button"
                        onAction="#cargarSubModulo" userData="/interface/AltaCliente.fxml" />

                <Button fx:id="btnFicha" text="FICHA CLIENTE" prefWidth="170.0" prefHeight="45.0" styleClass="menu-button"
                        onAction="#cargarSubModulo" userData="/interface/FichaCliente.fxml" />

                <Button fx:id="btnListar" text="LISTADO CLIENTE" prefWidth="170.0" prefHeight="45.0" styleClass="menu-button"
                        onAction="#cargarSubModulo" userData="/interface/listarClientes.fxml" />

                <Separator prefWidth="200.0" />


            </children>
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
            </padding>
        </VBox>

        <!-- Panel de contenido -->
        <AnchorPane fx:id="panelContenidoCliente" layoutX="200.0" layoutY="100.0"
                    AnchorPane.topAnchor="100.0" AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="0.0">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
            </padding>
            <Label text="Bienvenido al Módulo de Clientes." AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0" />
        </AnchorPane>
    </children>
</AnchorPane>
