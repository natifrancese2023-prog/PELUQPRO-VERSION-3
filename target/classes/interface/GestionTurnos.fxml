<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>


<AnchorPane fx:controller="controllers.GestionTurnosController"
            xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
            prefHeight="750.0" prefWidth="900.0"
            stylesheets="@/resource/styles.css">

    <children>

        <!-- Encabezado -->
        <HBox alignment="CENTER_LEFT" prefHeight="100.0" AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <ImageView fitHeight="86.0" fitWidth="140.0" preserveRatio="true">
                    <image>
                        <Image url="@747e63d5-c24e-4b1e-8622-61cde71cd610.png" />
                    </image>
                </ImageView>
                <VBox spacing="5.0">
                    <children>
                        <Label text="PeluqPro" styleClass="label-header">
                            <font>
                                <Font name="Candara" size="41.0" />
                            </font>
                        </Label>
                        <Label text="MÓDULO GESTIÓN DE TURNOS" styleClass="label-subsection" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
            </padding>
        </HBox>

        <!-- Menú lateral -->
        <VBox spacing="10.0" prefWidth="200.0"
              AnchorPane.topAnchor="100.0" AnchorPane.leftAnchor="0.0" AnchorPane.bottomAnchor="0.0">
            <children>
                <Label text="Seleccione una opción." />

                <Button fx:id="btnAlta" text="REGISTRAR TURNO" onAction="#cargarSubModulo"
                        userData="/interface/AltaTurno.fxml" prefHeight="45.0" prefWidth="170.0"
                        styleClass="menu-button" />

                <Button fx:id="btnGestionDiaria" text="GESTIONAR AGENDA DIARIA" onAction="#cargarSubModulo"
                        userData="/interface/GestionDiaria.fxml" prefHeight="45.0" prefWidth="170.0"
                        styleClass="menu-button" />

                <Separator prefWidth="200.0" />
                <Separator prefWidth="200.0" />

                <Button fx:id="btnVolverPanel" text="VOLVER" onAction="#handleVolverPanelPrincipal"
                        prefHeight="45.0" prefWidth="170.0" styleClass="menu-button-secondary" />
            </children>
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
            </padding>
        </VBox>

        <!-- Panel de contenido dinámico -->
        <AnchorPane fx:id="panelContenidoTurnos"
                    AnchorPane.topAnchor="100.0" AnchorPane.leftAnchor="200.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">
            <children>
                <Label text="Seleccione una opción del menú de Turnos."
                       AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0" />
            </children>
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
            </padding>
        </AnchorPane>

    </children>
</AnchorPane>
