<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.CargarVisitaController"
            stylesheets="@/resource/styles.css">
    <children>
        <VBox layoutX="10.0" layoutY="10.0" prefHeight="700.0" prefWidth="900.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <Label text="REGISTRO DE NUEVA VISITA" styleClass="label-header">
                <VBox.margin><Insets bottom="10.0" left="10.0" top="10.0" /></VBox.margin>
            </Label>

            <Label text="Cliente Seleccionado" style="-fx-font-weight: bold; -fx-font-size: 16px;">
                <VBox.margin><Insets left="15.0" bottom="5.0" top="10.0" /></VBox.margin>
            </Label>
            <HBox spacing="15.0" alignment="CENTER_LEFT"
                  style="-fx-border-color: #D3D8E0; -fx-border-radius: 5px; -fx-padding: 10px;">
                <Label text="Documento:" />
                <TextField fx:id="txtDocumentoCliente" editable="false" promptText="N° Documento"
                           prefWidth="150.0" styleClass="text-field" />
                <Label text="Nombre Completo:" />
                <TextField fx:id="txtNombreCliente" editable="false" promptText="Nombre del Cliente"
                           prefWidth="300.0" styleClass="text-field" />
            </HBox>

            <!-- 🔄 NUEVO BLOQUE: Turno asociado -->
            <Label text="Turno Asociado" style="-fx-font-weight: bold; -fx-font-size: 16px;">
                <VBox.margin><Insets left="15.0" bottom="5.0" top="20.0" /></VBox.margin>
            </Label>
            <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-padding: 10px;">
                <Label text="Seleccionar turno:" />
                <ComboBox fx:id="cmbTurnoCliente" prefWidth="600.0"
                          promptText="Turnos asignados al cliente" styleClass="combo-box" />
            </HBox>

            <Label text="Detalle de Servicios" style="-fx-font-weight: bold; -fx-font-size: 16px;">
                <VBox.margin><Insets left="15.0" bottom="5.0" top="20.0" /></VBox.margin>
            </Label>

            <HBox alignment="BOTTOM_LEFT" spacing="15.0">
                <children>
                    <VBox spacing="5.0">
                        <children>
                            <Label text="Tipo servicio" />
                            <ComboBox fx:id="cmbTipoServicio" prefWidth="180.0"
                                      promptText="Seleccionar servicio" styleClass="combo-box" />
                        </children>
                    </VBox>
                    <VBox spacing="5.0">
                        <children>
                            <Label text="Observaciones" />
                            <TextField fx:id="txtObservacionesServicio" prefWidth="350.0"
                                       promptText="Detalles u observaciones del servicio" styleClass="text-field" />
                        </children>
                    </VBox>

                    <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#handleAgregarServicio"
                            prefHeight="35.0" text="AGREGAR A LA LISTA" styleClass="secondary-button" />
                </children>
                <padding><Insets left="15.0" right="15.0" /></padding>
            </HBox>

            <TableView fx:id="tblServicios" prefHeight="300.0" prefWidth="850.0" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colFecha" prefWidth="100.0" text="Fecha Carga" />
                    <TableColumn fx:id="colServicio" prefWidth="200.0" text="Servicio" />
                    <TableColumn fx:id="colEstilista" prefWidth="150.0" text="Estilista (Usuario)" />
                    <TableColumn fx:id="colObservaciones" prefWidth="350.0" text="Observaciones/Detalle" />
                </columns>
                <VBox.margin><Insets top="20.0" left="15.0" right="15.0" /></VBox.margin>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" prefHeight="100.0" prefWidth="200.0" spacing="15.0">
                <children>
                    <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#handleVolver"
                            text="CANCELAR" styleClass="secondary-button" />
                    <Button fx:id="btnGuardarVisita" mnemonicParsing="false" onAction="#handleGuardarVisita"
                            text="FINALIZAR Y GUARDAR VISITA" styleClass="action-button" />
                </children>
                <padding><Insets right="15.0" /></padding>
            </HBox>

        </VBox>
    </children>
</AnchorPane>
