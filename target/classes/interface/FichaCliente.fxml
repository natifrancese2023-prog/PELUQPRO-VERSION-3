<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.FichaClienteController"
            stylesheets="@/resource/styles.css">

    <!-- Sección superior: búsqueda de cliente -->
    <top>
        <VBox spacing="15">
            <children>
                <Label text="Ficha del Cliente" styleClass="titulo-principal"/>
                <HBox spacing="10">
                    <children>
                        <Label text="Tipo de documento:"/>
                        <ComboBox fx:id="cmbTipoDocumento" prefWidth="150"/>
                        <Label text="Número:"/>
                        <TextField fx:id="txtDocumento" promptText="Ingrese documento..." prefWidth="200"/>
                        <Button text="Buscar" onAction="#buscarCliente" styleClass="boton-buscar"/>
                    </children>
                </HBox>
            </children>
            <VBox.margin>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </VBox.margin>
        </VBox>
    </top>

    <!-- Sección central: datos del cliente -->
    <center>
        <GridPane hgap="10" vgap="10">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <children>
                <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNombre" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Teléfono:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtTelefono" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Fecha de Alta:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtFechaAlta" editable="false" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </children>
        </GridPane>
    </center>

    <!-- Sección inferior: botones de acción -->
    <bottom>
        <HBox spacing="15" alignment="CENTER">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <children>
                <Button fx:id="btnModificar" text="Modificar" onAction="#modificarCliente" styleClass="boton-accion"/>
                <Button fx:id="btnEliminar" text="Eliminar" onAction="#eliminarCliente" styleClass="boton-accion"/>
                <Button fx:id="btnVerHistorial" text="Ver Historial" onAction="#verHistorial" styleClass="boton-accion"/>
                <Button fx:id="btnRegistrarVisita" text="Registrar Visita" onAction="#registrarVisita" styleClass="boton-accion"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>

